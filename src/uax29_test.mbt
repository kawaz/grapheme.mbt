  // ÷ 200C × 0308 ÷ 000D ÷
  let input = "\u{200C}\u{0308}\u{000D}"
  let g = graphemes(input)
  assert_eq(g.length(), 2)
  // cluster 0: [200C 0308]
  assert_eq(g[0].to_string(), "\u{200C}\u{0308}")
  // cluster 1: [000D]
  assert_eq(g[1].to_string(), "\u{000D}")
}

