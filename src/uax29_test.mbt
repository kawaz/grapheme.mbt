///|
test "UAX29/0734: LATIN SMALL LETTER A / REGIONAL INDICATOR SYMBOL L... / REGIONAL INDICATOR SYMBOL L... / REGIONAL INDICATOR SYMBOL L... / REGIONAL INDICATOR SYMBOL L... / LATIN SMALL LETTER B" {
  // ÷ 0061 ÷ 1F1E6 × 1F1E7 ÷ 1F1E8 × 1F1E9 ÷ 0062 ÷
  let input = "\u{0061}\u{1F1E6}\u{1F1E7}\u{1F1E8}\u{1F1E9}\u{0062}"
  let g = graphemes(input)
  assert_eq(g.length(), 4)
  // cluster 0: [0061]
  assert_eq(g[0].to_string(), "\u{0061}")
  // cluster 1: [1F1E6 1F1E7]
  assert_eq(g[1].to_string(), "\u{1F1E6}\u{1F1E7}")
  // cluster 2: [1F1E8 1F1E9]
  assert_eq(g[2].to_string(), "\u{1F1E8}\u{1F1E9}")
  // cluster 3: [0062]
  assert_eq(g[3].to_string(), "\u{0062}")
}

