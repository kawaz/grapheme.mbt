  let input = "\u{0915}\u{06DD}"
  let g = graphemes(input)
  assert_eq(g.length(), 2)
  // cluster 0: [0915]
  assert_eq(g[0].to_string(), "\u{0915}")
  // cluster 1: [06DD]
  assert_eq(g[1].to_string(), "\u{06DD}")
}

