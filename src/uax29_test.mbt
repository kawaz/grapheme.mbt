///|
test "UAX29/0723: <CARRIAGE RETURN / <LINE FEED / LATIN SMALL LETTER A / <LINE FEED / COMBINING DIAERESIS" {
  // ÷ 000D × 000A ÷ 0061 ÷ 000A ÷ 0308 ÷
  let input = "\u{000D}\u{000A}\u{0061}\u{000A}\u{0308}"
  let g = graphemes(input)
  assert_eq(g.length(), 4)
  // cluster 0: [000D 000A]
  assert_eq(g[0].to_string(), "\u{000D}\u{000A}")
  // cluster 1: [0061]
  assert_eq(g[1].to_string(), "\u{0061}")
  // cluster 2: [000A]
  assert_eq(g[2].to_string(), "\u{000A}")
  // cluster 3: [0308]
  assert_eq(g[3].to_string(), "\u{0308}")
}

