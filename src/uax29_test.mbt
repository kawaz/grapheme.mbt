  // ÷ 0378 × 0308 ÷ 000A ÷
  let input = "\u{0378}\u{0308}\u{000A}"
  let g = graphemes(input)
  assert_eq(g.length(), 2)
  // cluster 0: [0378 0308]
  assert_eq(g[0].to_string(), "\u{0378}\u{0308}")
  // cluster 1: [000A]
  assert_eq(g[1].to_string(), "\u{000A}")
}

