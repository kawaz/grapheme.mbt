  // ÷ 1160 ÷ 1100 ÷
  let input = "\u{1160}\u{1100}"
  let g = graphemes(input)
  assert_eq(g.length(), 2)
  // cluster 0: [1160]
  assert_eq(g[0].to_string(), "\u{1160}")
  // cluster 1: [1100]
  assert_eq(g[1].to_string(), "\u{1100}")
}

///|
