///|
test "UAX29/0761: BALINESE LETTER OKARA TEDUNG / BALINESE SIGN ULU CANDRA / BALINESE LETTER SA / BALINESE ADEG ADEG / BALINESE LETTER WA / BALINESE LETTER SA / BALINESE ADEG ADEG / BALINESE LETTER TA / BALINESE ADEG ADEG / BALINESE LETTER YA / BALINESE LETTER SA / BALINESE ADEG ADEG / BALINESE LETTER TA / BALINESE VOWEL SIGN SUKU" {
  // ÷ 1B12 × 1B01 ÷ 1B32 × 1B44 × 1B2F ÷ 1B32 × 1B44 × 1B22 × 1B44 × 1B2C ÷ 1B32 × 1B44 × 1B22 × 1B38 ÷
  let input = "\u{1B12}\u{1B01}\u{1B32}\u{1B44}\u{1B2F}\u{1B32}\u{1B44}\u{1B22}\u{1B44}\u{1B2C}\u{1B32}\u{1B44}\u{1B22}\u{1B38}"
  let g = graphemes(input)
  assert_eq(g.length(), 4)
  // cluster 0: [1B12 1B01]
  assert_eq(g[0].to_string(), "\u{1B12}\u{1B01}")
  // cluster 1: [1B32 1B44 1B2F]
  assert_eq(g[1].to_string(), "\u{1B32}\u{1B44}\u{1B2F}")
  // cluster 2: [1B32 1B44 1B22 1B44 1B2C]
  assert_eq(g[2].to_string(), "\u{1B32}\u{1B44}\u{1B22}\u{1B44}\u{1B2C}")
  // cluster 3: [1B32 1B44 1B22 1B38]
  assert_eq(g[3].to_string(), "\u{1B32}\u{1B44}\u{1B22}\u{1B38}")
}

