  let input = "\u{11A8}\u{0915}"
  let g = graphemes(input)
  assert_eq(g.length(), 2)
  // cluster 0: [11A8]
  assert_eq(g[0].to_string(), "\u{11A8}")
  // cluster 1: [0915]
  assert_eq(g[1].to_string(), "\u{0915}")
}

