  // ÷ 200D ÷ 00A9 ÷
  let input = "\u{200D}\u{00A9}"
  let from_iter = grapheme_iter(input).map(fn(v) { v.to_owned() }).collect()
  let from_view = graphemes(input).iter().map(fn(v) { v.to_owned() }).collect()
  assert_true(from_iter == from_view)
}

///|
test "UAX29/0262-iter: ZERO WIDTH JOINER / COMBINING DIAERESIS / COPYRIGHT SIGN" {
  // ÷ 200D × 0308 ÷ 00A9 ÷
  let input = "\u{200D}\u{0308}\u{00A9}"
  let from_iter = grapheme_iter(input).map(fn(v) { v.to_owned() }).collect()
  let from_view = graphemes(input).iter().map(fn(v) { v.to_owned() }).collect()
  assert_true(from_iter == from_view)
}

